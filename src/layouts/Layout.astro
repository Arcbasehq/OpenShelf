---
import SpeedInsights from "@vercel/speed-insights/astro";
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  canonical?: string;
}
const {
  title = "OpenShelf",
  description = "Discover, search, and read millions of books for free. OpenShelf is an open source book platform powered by Google Books.",
  image = "/og-default.png",
  type = "website",
  noindex = false,
  canonical,
} = Astro.props;

const siteUrl = "https://openshelf.vercel.app";
const fullTitle = title === "OpenShelf" ? "OpenShelf | Free and Open Source Books" : `${title} | OpenShelf`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image.startsWith("http") ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="OpenShelf" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#1a73e8" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="OpenShelf" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Google+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    <script is:inline>
      (function() {
        if (localStorage.getItem("theme") === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
        if (localStorage.getItem("mobile_view") === "true") {
          document.documentElement.setAttribute("data-mobile-view", "true");
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <header class="top-bar">
      <div class="top-bar-inner">
        <a href="/" class="logo">
          <svg class="logo-icon" width="30" height="30" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="16" y="96" width="96" height="10" rx="3" fill="#1a73e8"/>
            <path d="M64 30 C64 30 62 28 38 28 C28 28 22 30 22 30 L22 90 C22 90 28 88 38 88 C54 88 64 94 64 94 Z" fill="#e8f0fe" stroke="#1a73e8" stroke-width="4" stroke-linejoin="round"/>
            <path d="M64 30 C64 30 66 28 90 28 C100 28 106 30 106 30 L106 90 C106 90 100 88 90 88 C74 88 64 94 64 94 Z" fill="#e8f0fe" stroke="#1a73e8" stroke-width="4" stroke-linejoin="round"/>
            <line x1="64" y1="30" x2="64" y2="94" stroke="#1a73e8" stroke-width="4" stroke-linecap="round"/>
            <line x1="32" y1="46" x2="54" y2="46" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
            <line x1="32" y1="58" x2="52" y2="58" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
            <line x1="32" y1="70" x2="54" y2="70" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
            <line x1="74" y1="46" x2="96" y2="46" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
            <line x1="76" y1="58" x2="96" y2="58" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
            <line x1="74" y1="70" x2="96" y2="70" stroke="#1a73e8" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
          </svg>
          OpenShelf
        </a>
        <nav class="nav-links">
          <a href="/search">Search</a>
          <a href="/books">Browse</a>
          <a href="/favorites">My Library</a>
        </nav>
        <button class="btn btn-text theme-toggle" id="theme-toggle" title="Toggle dark mode" style="padding:0 8px">
          <span class="material-symbols-outlined" style="font-size:20px" id="theme-icon">dark_mode</span>
        </button>
        <div class="nav-auth" id="auth-area">
          <a href="/login" class="btn btn-text">Sign in</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span>&copy; 2026 OpenShelf. All rights reserved.</span>
        <span class="footer-sep">|</span>
        <span>Made by <a href="https://arcbase.one" target="_blank" rel="noopener noreferrer">Arcbase</a></span>
      </div>
    </footer>

    <!-- Cookie Consent Banner -->
    <div class="cookie-banner" id="cookie-banner">
      <div class="cookie-inner">
        <span class="material-symbols-outlined cookie-icon">cookie</span>
        <div class="cookie-text">
          <p>We use cookies and local storage to improve your experience, remember your preferences, and keep you signed in.</p>
        </div>
        <div class="cookie-actions">
          <button class="btn btn-outline cookie-decline" id="cookie-decline">Decline</button>
          <button class="btn btn-primary cookie-accept" id="cookie-accept">Accept</button>
        </div>
      </div>
    </div>

    <script>
      import { ConvexClient } from "convex/browser";

      const CONVEX_URL = import.meta.env.PUBLIC_CONVEX_URL;
      if (CONVEX_URL) {
        const client = new ConvexClient(CONVEX_URL);
        const token = localStorage.getItem("convex_token");
        if (token) {
          client.setAuth(() => Promise.resolve(token));
        }
        (window as any).__convex = client;
      }

      // Update auth area based on login state
      const authArea = document.getElementById("auth-area");
      if (authArea) {
        const token = localStorage.getItem("convex_token");
        if (token) {
          let userName = localStorage.getItem("user_name") || "";
          let userEmail = localStorage.getItem("user_email") || "";

          // If user info is missing (e.g. logged in before it was stored), fetch it
          if (!userName && !userEmail) {
            try {
              const res = await fetch("/api/auth/me", {
                headers: { Authorization: "Bearer " + token },
              });
              if (res.ok) {
                const user = await res.json();
                userName = user.name || "";
                userEmail = user.email || "";
                if (userName) localStorage.setItem("user_name", userName);
                if (userEmail) localStorage.setItem("user_email", userEmail);
              }
            } catch {}
          }

          const initial = (userName || userEmail || "?").charAt(0).toUpperCase();

          authArea.innerHTML = `
            <div class="avatar-menu">
              <button class="avatar-btn" id="avatar-btn" title="${userName || userEmail || 'Account'}">
                <span class="avatar-initial">${initial}</span>
              </button>
              <div class="avatar-dropdown" id="avatar-dropdown">
                <div class="dropdown-header">
                  <span class="dropdown-name">${userName || "User"}</span>
                  <span class="dropdown-email">${userEmail}</span>
                </div>
                <div class="dropdown-divider"></div>
                <a href="/favorites" class="dropdown-item">
                  <span class="material-symbols-outlined">collections_bookmark</span>
                  My Library
                </a>
                <a href="/settings" class="dropdown-item">
                  <span class="material-symbols-outlined">settings</span>
                  Settings
                </a>
                <div class="dropdown-divider"></div>
                <button class="dropdown-item dropdown-logout" id="logout-btn">
                  <span class="material-symbols-outlined">logout</span>
                  Sign out
                </button>
              </div>
            </div>`;

          const avatarBtn = document.getElementById("avatar-btn");
          const dropdown = document.getElementById("avatar-dropdown");

          avatarBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            dropdown?.classList.toggle("open");
          });

          document.addEventListener("click", () => {
            dropdown?.classList.remove("open");
          });

          dropdown?.addEventListener("click", (e) => {
            e.stopPropagation();
          });

          document.getElementById("logout-btn")?.addEventListener("click", () => {
            localStorage.removeItem("convex_token");
            localStorage.removeItem("user_name");
            localStorage.removeItem("user_email");
            window.location.href = "/";
          });
        }
      }

      // Theme toggle
      const themeToggle = document.getElementById("theme-toggle");
      const themeIcon = document.getElementById("theme-icon");
      function updateThemeIcon() {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        if (themeIcon) themeIcon.textContent = isDark ? "light_mode" : "dark_mode";
      }
      updateThemeIcon();
      themeToggle?.addEventListener("click", () => {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        if (isDark) {
          document.documentElement.removeAttribute("data-theme");
          localStorage.setItem("theme", "light");
        } else {
          document.documentElement.setAttribute("data-theme", "dark");
          localStorage.setItem("theme", "dark");
        }
        updateThemeIcon();
      });

      // Cookie consent banner
      const cookieBanner = document.getElementById("cookie-banner");
      const cookieConsent = localStorage.getItem("cookie_consent");
      if (cookieBanner && !cookieConsent) {
        cookieBanner.classList.add("visible");
      }
      document.getElementById("cookie-accept")?.addEventListener("click", () => {
        localStorage.setItem("cookie_consent", "accepted");
        cookieBanner?.classList.remove("visible");
      });
      document.getElementById("cookie-decline")?.addEventListener("click", () => {
        localStorage.setItem("cookie_consent", "declined");
        cookieBanner?.classList.remove("visible");
        // Clear non-essential storage
        localStorage.removeItem("theme");
      });
    </script>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --color-bg: #ffffff;
        --color-surface: #ffffff;
        --color-surface-variant: #f8f9fa;
        --color-primary: #1a73e8;
        --color-primary-hover: #1765cc;
        --color-primary-container: #d2e3fc;
        --color-primary-light: #e8f0fe;
        --color-on-primary: #ffffff;
        --color-text: #202124;
        --color-text-secondary: #5f6368;
        --color-text-tertiary: #80868b;
        --color-border: #e0e0e0;
        --color-border-light: #f1f3f4;
        --color-danger: #d93025;
        --color-danger-light: #fce8e6;
        --color-success: #1e8e3e;
        --radius-xs: 4px;
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --radius-full: 100px;
        --shadow-sm: 0 1px 3px rgba(60,64,67,.08), 0 1px 2px rgba(60,64,67,.04);
        --shadow-md: 0 1px 3px rgba(60,64,67,.15), 0 4px 8px rgba(60,64,67,.1);
        --shadow-lg: 0 8px 16px rgba(60,64,67,.1), 0 1px 3px rgba(60,64,67,.15);
        --shadow-xl: 0 12px 28px rgba(60,64,67,.12), 0 2px 6px rgba(60,64,67,.1);
        --max-w: 1280px;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-display: 'Google Sans', 'Inter', system-ui, -apple-system, sans-serif;
        --ease: cubic-bezier(0.2, 0, 0, 1);
        --duration: 200ms;
      }

      :root[data-theme="dark"] {
        --color-bg: #1a1a2e;
        --color-surface: #16213e;
        --color-surface-variant: #1a1a2e;
        --color-primary: #64b5f6;
        --color-primary-hover: #90caf9;
        --color-primary-container: #1a3a5c;
        --color-primary-light: #0d253f;
        --color-on-primary: #0a1628;
        --color-text: #e8eaed;
        --color-text-secondary: #9aa0a6;
        --color-text-tertiary: #6b7280;
        --color-border: #2d3748;
        --color-border-light: #232b3e;
        --color-danger: #f28b82;
        --color-danger-light: #3c1f1e;
        --color-success: #81c995;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.3), 0 1px 2px rgba(0,0,0,.2);
        --shadow-md: 0 1px 3px rgba(0,0,0,.4), 0 4px 8px rgba(0,0,0,.3);
        --shadow-lg: 0 8px 16px rgba(0,0,0,.3), 0 1px 3px rgba(0,0,0,.4);
        --shadow-xl: 0 12px 28px rgba(0,0,0,.4), 0 2px 6px rgba(0,0,0,.3);
      }

      html {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        font-size: 14px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color var(--duration) var(--ease);
      }
      a:hover {
        text-decoration: underline;
      }

      img {
        display: block;
      }

      /* ── Top Bar ── */
      .top-bar {
        background: var(--color-surface);
        border-bottom: 1px solid var(--color-border-light);
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(8px);
      }
      .top-bar-inner {
        display: flex;
        align-items: center;
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 24px;
        height: 64px;
        gap: 8px;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 500;
        color: var(--color-text);
        letter-spacing: -0.3px;
        white-space: nowrap;
        margin-right: 16px;
      }
      .logo:hover { text-decoration: none; }
      .logo-icon { flex-shrink: 0; }
      .nav-links {
        display: flex;
        gap: 2px;
        margin-left: auto;
      }
      .nav-links a {
        padding: 8px 16px;
        border-radius: var(--radius-full);
        color: var(--color-text-secondary);
        font-weight: 500;
        font-size: 14px;
        transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
      }
      .nav-links a:hover {
        background: var(--color-primary-light);
        color: var(--color-primary);
        text-decoration: none;
      }
      .nav-auth {
        margin-left: 8px;
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .theme-toggle {
        margin-left: 0;
      }

      /* ── Avatar Menu ── */
      .avatar-menu {
        position: relative;
      }
      .avatar-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: var(--color-primary);
        color: var(--color-on-primary);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: box-shadow var(--duration) var(--ease), opacity var(--duration) var(--ease);
      }
      .avatar-btn:hover {
        box-shadow: var(--shadow-sm);
        opacity: 0.9;
      }
      .avatar-initial {
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 500;
        line-height: 1;
        user-select: none;
      }
      .avatar-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 220px;
        background: var(--color-surface);
        border: 1px solid var(--color-border-light);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px) scale(0.96);
        transition: opacity 150ms var(--ease), transform 150ms var(--ease), visibility 150ms;
        z-index: 200;
        overflow: hidden;
      }
      .avatar-dropdown.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
      }
      .dropdown-header {
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .dropdown-name {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 14px;
        color: var(--color-text);
      }
      .dropdown-email {
        font-size: 12px;
        color: var(--color-text-tertiary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .dropdown-divider {
        height: 1px;
        background: var(--color-border-light);
      }
      .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        font-size: 14px;
        color: var(--color-text-secondary);
        background: none;
        border: none;
        width: 100%;
        cursor: pointer;
        font-family: var(--font-sans);
        transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
        text-decoration: none;
      }
      .dropdown-item:hover {
        background: var(--color-primary-light);
        color: var(--color-primary);
        text-decoration: none;
      }
      .dropdown-item .material-symbols-outlined {
        font-size: 20px;
      }
      .dropdown-logout {
        color: var(--color-danger);
      }
      .dropdown-logout:hover {
        background: var(--color-danger-light);
        color: var(--color-danger);
      }

      /* ── Buttons ── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 24px;
        height: 40px;
        border-radius: var(--radius-full);
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 14px;
        cursor: pointer;
        border: none;
        transition: all var(--duration) var(--ease);
        white-space: nowrap;
        user-select: none;
        letter-spacing: 0.01em;
      }
      .btn .material-symbols-outlined {
        font-size: 18px;
      }
      .btn-primary {
        background: var(--color-primary);
        color: var(--color-on-primary);
        box-shadow: none;
      }
      .btn-primary:hover {
        background: var(--color-primary-hover);
        box-shadow: var(--shadow-sm);
        text-decoration: none;
      }
      .btn-outline {
        background: transparent;
        border: 1px solid var(--color-border);
        color: var(--color-primary);
      }
      .btn-outline:hover {
        background: var(--color-primary-light);
        border-color: var(--color-primary-container);
        text-decoration: none;
      }
      .btn-text {
        background: transparent;
        color: var(--color-primary);
        padding: 0 12px;
      }
      .btn-text:hover {
        background: var(--color-primary-light);
        text-decoration: none;
      }
      .btn-danger {
        background: var(--color-danger);
        color: #fff;
      }
      .btn-danger:hover {
        background: #c5221f;
        box-shadow: var(--shadow-sm);
      }
      .btn-tonal {
        background: var(--color-primary-light);
        color: var(--color-primary);
      }
      .btn-tonal:hover {
        background: var(--color-primary-container);
        text-decoration: none;
      }
      .btn:disabled {
        opacity: 0.38;
        cursor: default;
        pointer-events: none;
      }

      /* ── Main ── */
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 32px 24px 64px;
        min-height: calc(100vh - 64px - 52px);
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--color-border-light);
        background: var(--color-surface-variant);
      }
      .footer-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 12px;
        color: var(--color-text-tertiary);
      }
      .footer-inner a {
        color: var(--color-text-tertiary);
      }
      .footer-inner a:hover {
        color: var(--color-text-secondary);
      }
      .footer-sep {
        color: var(--color-border);
      }

      /* ── Book Grid ── */
      .book-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(172px, 1fr));
        gap: 24px;
      }
      .book-card {
        background: var(--color-surface);
        border-radius: var(--radius-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow var(--duration) var(--ease), transform var(--duration) var(--ease);
        position: relative;
        border: 1px solid var(--color-border-light);
      }
      .book-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
        border-color: transparent;
      }
      .book-card .cover-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 2 / 3;
        background: var(--color-surface-variant);
        overflow: hidden;
      }
      .book-card .cover-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.4s var(--ease);
        image-rendering: auto;
        position: relative;
        z-index: 1;
      }
      .book-card .cover-wrap img[data-loaded="false"] {
        opacity: 0;
      }
      .book-card .cover-wrap img[data-loaded="true"] {
        opacity: 1;
      }
      .book-card .cover-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-surface-variant);
        z-index: 0;
      }
      .book-card .cover-placeholder .material-symbols-outlined {
        font-size: 40px;
        color: var(--color-text-tertiary);
      }
      .book-card .card-body {
        padding: 12px 14px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .book-card .card-title {
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 13px;
        color: var(--color-text);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        letter-spacing: -0.01em;
      }
      .book-card .card-title:hover {
        color: var(--color-primary);
        text-decoration: none;
      }
      .book-card .card-authors {
        color: var(--color-text-tertiary);
        font-size: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        letter-spacing: 0;
      }
      .book-card .card-actions {
        margin-top: auto;
        padding-top: 8px;
        display: flex;
        gap: 8px;
      }
      .book-card .card-actions .btn {
        height: 30px;
        font-size: 12px;
        padding: 0 12px;
        border-radius: var(--radius-sm);
      }

      /* ── Search Bar ── */
      .search-bar {
        display: flex;
        align-items: center;
        max-width: 720px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        padding: 0 6px 0 20px;
        height: 52px;
        transition: box-shadow var(--duration) var(--ease), border-color var(--duration) var(--ease);
        margin-bottom: 32px;
      }
      .search-bar:focus-within {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px var(--color-primary-light);
      }
      .search-bar .material-symbols-outlined {
        color: var(--color-text-tertiary);
        font-size: 22px;
        margin-right: 12px;
        flex-shrink: 0;
      }
      .search-bar input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 16px;
        font-family: var(--font-sans);
        color: var(--color-text);
        background: transparent;
        height: 100%;
      }
      .search-bar input::placeholder {
        color: var(--color-text-tertiary);
      }
      .search-bar .btn {
        height: 40px;
        border-radius: var(--radius-full);
        padding: 0 20px;
      }

      /* ── Section Headings ── */
      .section-title {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 400;
        color: var(--color-text);
        margin-bottom: 8px;
        letter-spacing: -0.3px;
      }
      .section-subtitle {
        font-size: 14px;
        color: var(--color-text-secondary);
        margin-bottom: 28px;
        line-height: 1.5;
      }

      /* ── Chips ── */
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0 14px;
        height: 32px;
        border-radius: var(--radius-full);
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        font-size: 13px;
        color: var(--color-text-secondary);
        font-weight: 400;
        transition: background var(--duration) var(--ease);
      }
      .chip:hover {
        background: var(--color-surface-variant);
      }

      /* ── Utility ── */
      .text-center { text-align: center; }
      .text-secondary { color: var(--color-text-secondary); }
      .mt-1 { margin-top: 16px; }
      .mt-2 { margin-top: 32px; }
      .mt-3 { margin-top: 48px; }

      /* ── Empty State ── */
      .empty-state {
        text-align: center;
        padding: 80px 24px;
      }
      .empty-state .material-symbols-outlined {
        font-size: 56px;
        color: var(--color-border);
        margin-bottom: 20px;
      }
      .empty-state .btn .material-symbols-outlined {
        font-size: 18px;
        color: inherit;
        margin-bottom: 0;
      }
      .empty-state h2 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 400;
        margin-bottom: 8px;
        color: var(--color-text);
      }
      .empty-state p {
        font-size: 14px;
        color: var(--color-text-secondary);
        margin-bottom: 24px;
        line-height: 1.5;
      }

      /* ── Cookie Banner ── */
      .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        transform: translateY(100%);
        opacity: 0;
        transition: transform 350ms var(--ease), opacity 350ms var(--ease);
        pointer-events: none;
      }
      .cookie-banner.visible {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }
      .cookie-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--color-surface);
        border-top: 1px solid var(--color-border-light);
        box-shadow: 0 -4px 16px rgba(0,0,0,.08);
      }
      :root[data-theme="dark"] .cookie-inner {
        box-shadow: 0 -4px 16px rgba(0,0,0,.3);
      }
      .cookie-icon {
        font-size: 28px;
        color: var(--color-primary);
        flex-shrink: 0;
      }
      .cookie-text p {
        font-size: 13px;
        color: var(--color-text-secondary);
        line-height: 1.5;
        margin: 0;
      }
      .cookie-actions {
        display: flex;
        gap: 8px;
        flex-shrink: 0;
      }
      .cookie-actions .btn {
        height: 36px;
        padding: 0 20px;
        font-size: 13px;
      }
      @media (max-width: 768px) {
        .cookie-inner {
          flex-wrap: wrap;
          padding: 16px;
          gap: 12px;
        }
        .cookie-icon { display: none; }
        .cookie-actions { width: 100%; }
        .cookie-actions .btn { flex: 1; }
      }

      /* ── Mobile View (App Mode) ── */
      :root[data-mobile-view="true"] {
        --safe-top: env(safe-area-inset-top, 0px);
        --safe-bottom: env(safe-area-inset-bottom, 0px);
      }
      :root[data-mobile-view="true"] .top-bar {
        padding-top: var(--safe-top);
      }
      :root[data-mobile-view="true"] .top-bar-inner {
        padding: 0 12px;
        height: 52px;
        gap: 4px;
      }
      :root[data-mobile-view="true"] .logo {
        font-size: 16px;
        margin-right: 8px;
        gap: 8px;
      }
      :root[data-mobile-view="true"] .logo-icon {
        width: 24px;
        height: 24px;
      }
      :root[data-mobile-view="true"] .nav-links {
        gap: 0;
      }
      :root[data-mobile-view="true"] .nav-links a {
        padding: 6px 10px;
        font-size: 13px;
      }
      :root[data-mobile-view="true"] .theme-toggle {
        padding: 0 6px !important;
      }
      :root[data-mobile-view="true"] main {
        padding: 16px 12px 80px;
        min-height: calc(100vh - 52px - var(--safe-top) - var(--safe-bottom));
      }
      :root[data-mobile-view="true"] .book-grid {
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 12px;
      }
      :root[data-mobile-view="true"] .book-card .card-body {
        padding: 10px 12px;
      }
      :root[data-mobile-view="true"] .book-card .card-title {
        font-size: 12px;
      }
      :root[data-mobile-view="true"] .book-card .card-authors {
        font-size: 11px;
      }
      :root[data-mobile-view="true"] .search-bar {
        height: 46px;
        margin-bottom: 20px;
        padding: 0 4px 0 16px;
      }
      :root[data-mobile-view="true"] .search-bar input {
        font-size: 15px;
      }
      :root[data-mobile-view="true"] footer {
        padding-bottom: var(--safe-bottom);
      }
      :root[data-mobile-view="true"] .footer-inner {
        padding: 12px 12px;
        font-size: 11px;
        flex-wrap: wrap;
        gap: 6px;
      }
      :root[data-mobile-view="true"] .section-title {
        font-size: 20px;
      }
      :root[data-mobile-view="true"] .section-subtitle {
        font-size: 13px;
        margin-bottom: 20px;
      }
      :root[data-mobile-view="true"] .empty-state {
        padding: 48px 16px;
      }
      :root[data-mobile-view="true"] .avatar-dropdown {
        min-width: 200px;
      }
      :root[data-mobile-view="true"] .cookie-inner {
        flex-wrap: wrap;
        padding: 14px 12px;
        gap: 10px;
        padding-bottom: calc(14px + var(--safe-bottom));
      }
      :root[data-mobile-view="true"] .cookie-icon {
        display: none;
      }
      :root[data-mobile-view="true"] .cookie-actions {
        width: 100%;
      }
      :root[data-mobile-view="true"] .cookie-actions .btn {
        flex: 1;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .top-bar-inner { padding: 0 16px; gap: 8px; }
        main { padding: 24px 16px 48px; }
        .book-grid {
          grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
          gap: 16px;
        }
      }
      @media (max-width: 480px) {
        .nav-links { gap: 0; }
        .nav-links a { padding: 8px 10px; font-size: 13px; }
        .book-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 12px;
        }
        .search-bar { height: 48px; }
      }
    </style>
    <SpeedInsights />
  </body>
</html>
